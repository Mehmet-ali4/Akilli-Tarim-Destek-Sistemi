{
  "name": "akilli-tarim-frontend-tests",
  "version": "1.0.0",
  "description": "Akıllı Tarım Destek Sistemi - Frontend Test Suite",
  "scripts": {
    "test": "jest --verbose --coverage",
    "test:watch": "jest --watch --verbose"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/js/**/*.test.js"
    ],
    "coverageDirectory": "coverage"
  }
}
